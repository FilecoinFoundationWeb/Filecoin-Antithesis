# ═══════════════════════════════════════════════════════════════════
# versions.env — Image version pins
# ═══════════════════════════════════════════════════════════════════
#
# This is the main file teams edit. Change a version, open a PR, CI runs.
#
# Values: "latest" for HEAD, or a commit hash / git tag for a pin.
#   Examples: latest, 42d68a5, v1.32.0
#
# See test.env for test parameters (duration, notebook, etc.)
# See .env for network heights and fork schedule.
# ═══════════════════════════════════════════════════════════════════

# Implementation versions — commit hashes or tags from upstream repos
LOTUS0_COMMIT=latest
LOTUS1_COMMIT=latest
FOREST_COMMIT=latest
CURIO_COMMIT=latest
DRAND_COMMIT=latest

# Internal versions — built from this repo's code
WORKLOAD_TAG=latest
FILWIZARD_TAG=latest
CONFIG_TAG=latest
