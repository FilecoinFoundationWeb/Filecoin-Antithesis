# ═══════════════════════════════════════════════════════════════════
# test.env — Test execution parameters
# ═══════════════════════════════════════════════════════════════════
#
# These control HOW a test runs, not WHAT runs.
# Edit versions.env for image versions, .env for network config.

# Antithesis notebook: "filecoin" (base) or "filecoin-foc" (FOC profile)
NOTEBOOK=filecoin

# Test duration in hours
DURATION=1.5

# Email recipients for test results (comma-separated, leave empty for none)
EMAILS=

# Ephemeral test — doesn't affect the findings baseline
EPHEMERAL=true
